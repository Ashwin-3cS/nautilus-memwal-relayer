# ── MemWal Relay Server Configuration ────────────────────────────────────────
# Copy to .env.runtime (gitignored) and fill in real values before deploying.
# These are sent into the enclave via VSOCK port 7000 as KEY=VALUE pairs.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Database (external Postgres with pgvector) ────────────────────────────────
# NOTE: Host must be reachable from the EC2 instance (RDS, ElastiCache, etc.)
# The enclave proxies TCP traffic via socat VSOCK → host → DB.
DATABASE_URL=postgresql://memwal:changeme@your-rds-host.rds.amazonaws.com:5432/memwal

# ── Redis (external, for rate limiting) ──────────────────────────────────────
REDIS_URL=redis://your-redis-host.cache.amazonaws.com:6379

# ── Sui ───────────────────────────────────────────────────────────────────────
SUI_NETWORK=mainnet
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443

# ── MemWal on-chain objects ───────────────────────────────────────────────────
MEMWAL_PACKAGE_ID=0x
MEMWAL_REGISTRY_ID=0x

# ── SEAL (encryption key servers) ────────────────────────────────────────────
# Comma-separated on-chain object IDs
SEAL_KEY_SERVERS=0x,0x
# Comma-separated HTTPS endpoint URLs (used by run.sh to set up outbound proxies)
SEAL_KEY_SERVER_URLS=https://seal-key-server-0.example.com,https://seal-key-server-1.example.com

# ── Sui signing keys ──────────────────────────────────────────────────────────
# Primary key used for SEAL decrypt authorization
SERVER_SUI_PRIVATE_KEY=suiprivkey1...
# Pool of keys for parallel Walrus uploads (comma-separated, can be same as above)
SERVER_SUI_PRIVATE_KEYS=suiprivkey1...

# ── Walrus blob storage ───────────────────────────────────────────────────────
WALRUS_PUBLISHER_URL=https://publisher.walrus-mainnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space

# ── OpenAI (fact extraction + embeddings) ────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_API_BASE=https://api.openai.com/v1

# ── Enoki (optional — sponsored transactions) ─────────────────────────────────
ENOKI_API_KEY=
# ENOKI_NETWORK=mainnet
# ENOKI_FALLBACK_TO_DIRECT_SIGN=true

# ── Sidecar (set automatically by run.sh inside enclave, override for local dev) ──
SIDECAR_URL=http://127.0.0.1:9000
SIDECAR_PORT=9000
# SIDECAR_SCRIPTS_DIR=/scripts

# ── VSOCK port assignments ────────────────────────────────────────────────────
# These define which VSOCK port maps to which outbound endpoint.
# Both run.sh (inside enclave) and parent_forwarder.sh (host) use the same values.
# Change only if you have port conflicts on your EC2 host.
SUI_PROXY_VSOCK_PORT=8101
WALRUS_PUBLISHER_PROXY_VSOCK_PORT=8102
WALRUS_AGGREGATOR_PROXY_VSOCK_PORT=8103
POSTGRES_PROXY_VSOCK_PORT=8104
REDIS_PROXY_VSOCK_PORT=8105
OPENAI_PROXY_VSOCK_PORT=8106
# Base port for SEAL key servers; each additional server uses base+N
SEAL_BASE_VSOCK_PORT=8107
